{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "composite": true,
    "outDir": "./dist",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@formatters/*": ["./src/formatters/*"],
      "@utils": ["./src/utils.ts"]
    }
  },
  "include": ["src"]
}
