                    "value": "CHS"
                  }
                ]
              }
            ]
          }
        }
      ],
      "type": "derived",
      "key": "M_y_V_Rd",
      "valueType": {
        "type": "number"
      },
      "meta": {
        "sectionRef": "6.2.8",
        "formulaRef": "(6.30)"
      },
      "unit": "\\mathrm{N\\cdot mm}"
    },
    "M_y_V_Rd_i": {
      "id": "M_y_V_Rd_i",
      "name": "I-section reduced bending resistance about y-y under shear",
      "symbol": "M_{y,V,Rd,i}",
      "children": [
        {
          "nodeId": "W_y_res"
        },
        {
          "nodeId": "rho_z"
        },
        {
          "nodeId": "A_w"
