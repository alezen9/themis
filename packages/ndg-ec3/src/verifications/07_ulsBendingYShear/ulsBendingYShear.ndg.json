      "valueType": {
        "type": "number"
      },
      "meta": {
        "sectionRef": "6.2.8",
        "formulaRef": "(6.30)"
      },
      "expression": "\\frac{\\left(W_{y,res} - \\rho \\dfrac{A_w^2}{4t_w}\\right) \\cdot f_y}{\\gamma_{M0}} \\leq M_{c,y,Rd}",
      "unit": "\\mathrm{N\\cdot mm}"
    },
