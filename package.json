{
  "name": "themis",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:frontend": "pnpm --dir apps/frontend test",
    "dev": "pnpm --filter frontend dev",
    "ndg:editor-to-nodes": "node scripts/ndg-editor-to-nodes.mjs",
    "ndg:nodes-to-editor": "node scripts/ndg-nodes-to-editor.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.7",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
